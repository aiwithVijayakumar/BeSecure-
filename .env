# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production

# ─── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
MAX_UPLOAD_SIZE_MB=100

# ─── Ollama (LLM) ──────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Models
CODE_ANALYSIS_MODEL=deepseek-coder:latest
REASONING_MODEL=llama3:8b
FAST_MODEL=llama3:8b

# ─── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_OWASP=owasp_knowledge
CHROMA_COLLECTION_SDLC=sdlc_knowledge

# ─── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── MobSF (Optional) ─────────────────────────────────────────────────────────
MOBSF_URL=http://localhost:8002
MOBSF_API_KEY=your-mobsf-api-key

# ─── JADX / APKTool ───────────────────────────────────────────────────────────
JADX_PATH=jadx
APKTOOL_PATH=apktool
